{
  "name": "aerolink",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "services/*",
    "webui"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "packages:build": "npm run build --workspace=packages/shared-kernel --workspace=packages/events --workspace=packages/common-middleware",
    "dev": "turbo run dev --parallel",
    "dev:local": "npm run packages:build && turbo run dev --parallel",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "~5.4.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0"
  },
  "packageManager": "npm@11.14.1",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "uuid": "11.1.1",
    "xml2js": "0.6.0",
    "tar": "7.5.15",
    "@mapbox/node-pre-gyp": {
      "tar": "7.5.15"
    }
  }
}
