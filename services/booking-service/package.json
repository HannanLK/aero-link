{
    "name":  "@aerolink/booking-service",
    "version":  "1.0.0",
    "private":  true,
    "scripts":  {
                    "lint":  "echo \u0027lint: no eslint configured\u0027",
                    "build":  "prisma generate \u0026\u0026 nest build",
                    "start:prod":  "node dist/main",
                    "start:dev":  "nest start --watch",
                    "dev":  "nest start --watch",
                    "test":  "prisma generate \u0026\u0026 jest",
                    "prisma:generate":  "prisma generate",
                    "prisma:migrate":  "prisma migrate deploy"
                },
    "dependencies":  {
                         "@aerolink/common-middleware":  "*",
                         "@aerolink/events":  "*",
                         "@aerolink/shared-kernel":  "*",
                         "@nestjs/common":  "^11.1.0",
                         "@nestjs/config":  "^4.0.0",
                         "@nestjs/core":  "^11.1.0",
                         "@nestjs/platform-fastify":  "^11.1.0",
                         "@nestjs/swagger":  "^11.4.4",
                         "@nestjs/terminus":  "^11.1.0",
                         "@prisma/client":  "^5.14.0",
                         "class-transformer":  "^0.5.1",
                         "class-validator":  "^0.14.1",
                         "kafkajs":  "^2.2.4",
                         "reflect-metadata":  "^0.2.2",
                         "rxjs":  "^7.8.1",
                         "uuid":  "^11.1.1",
                         "@fastify/static":  "^8.1.0"
                     },
    "devDependencies":  {
                            "@nestjs/cli":  "^11.0.0",
                            "@nestjs/schematics":  "^11.0.0",
                            "@nestjs/testing":  "^11.1.0",
                            "@types/jest":  "^29.5.12",
                            "@types/node":  "^20.14.2",
                            "jest":  "^29.7.0",
                            "prisma":  "^5.14.0",
                            "ts-jest":  "^29.1.4",
                            "typescript":  "~5.4.0"
                        },
    "jest":  {
                 "moduleFileExtensions":  [
                                              "js",
                                              "json",
                                              "ts"
                                          ],
                 "rootDir":  "src",
                 "testRegex":  ".*\\.spec\\.ts$",
                 "transform":  {
                                   "^.+\\.(t|j)s$":  "ts-jest"
                               },
                 "coverageDirectory":  "../coverage",
                 "testEnvironment":  "../jest.env.js"
             }
}
