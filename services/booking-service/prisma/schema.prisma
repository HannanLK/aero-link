generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookingStatus {
  PENDING
  AWAITING_SEAT_LOCK
  SEAT_LOCKED
  AWAITING_PAYMENT
  CONFIRMED
  COMPENSATING
  CANCELLED
}

model Booking {
  id              String        @id @default(uuid()) @db.Uuid
  idempotencyKey  String        @unique
  passengerId     String        @db.Uuid
  flightId        String        @db.Uuid
  seatNumber      String
  status          BookingStatus @default(PENDING)
  totalAmount     Decimal       @db.Decimal(10, 2)
  currency        String        @db.Char(3) @default("USD")
  paymentRef      String?
  cancelReason    String?
  sagaHistory     Json          @default("[]")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([passengerId])
  @@index([flightId])
  @@map("bookings")
}
