# Copy to terraform.tfvars and fill in real values.
# NEVER commit terraform.tfvars — it is gitignored.

aws_region   = "us-east-1"
environment  = "dev"
project      = "aerolink"
domain_name  = "aerolink.app"

eks_kubernetes_version   = "1.30"
eks_node_instance_type   = "t3.medium"
eks_node_min             = 2
eks_node_max             = 6
eks_node_desired         = 2

aurora_instance_class    = "db.t3.medium"
aurora_engine_version    = "16.2"
redis_node_type          = "cache.t3.micro"
msk_broker_instance_type = "kafka.t3.small"
msk_kafka_version        = "3.6.0"

notification_email_sender = "noreply@aerolink.app"
alert_email               = "ops@aerolink.app"

# Set via TF_VAR_db_master_password environment variable in CI — do not put here
# db_master_password = ""
